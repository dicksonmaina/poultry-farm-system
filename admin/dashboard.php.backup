    <script>
        // Chart.js defaults
        Chart.defaults.color = '#6b7280';
        Chart.defaults.font.family = 'Inter';
        
        const chartConfig = {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { display: true, labels: { color: '#6b7280', font: { size: 12 } } },
                filler: { propagate: true }
            },
            scales: {
                x: { grid: { color: 'rgba(34,197,94,0.05)', drawBorder: false }, ticks: { color: '#6b7280', font: { size: 11 } } },
                y: { grid: { color: 'rgba(34,197,94,0.05)', drawBorder: false }, ticks: { color: '#6b7280', font: { size: 11 } } }
            }
        };
        
        // Egg production chart
        const eggCtx = document.getElementById('eggChart').getContext('2d');
        const eggChart = new Chart(eggCtx, {
            type: 'line',
            data: {
                labels: <?= json_encode($egg_dates) ?>,
                datasets: [{
                    label: 'Daily Eggs',
                    data: <?= json_encode($egg_values) ?>,
                    borderColor: '#22c55e',
                    backgroundColor: 'rgba(34,197,94,0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 0,
                    pointHoverRadius: 6,
                    pointHoverBorderWidth: 2,
                    borderWidth: 2,
                    pointHoverBackgroundColor: '#22c55e'
                }]
            },
            options: { ...chartConfig }
        });
        
        // FCR chart
        const fcrCtx = document.getElementById('fcrChart').getContext('2d');
        const fcrChart = new Chart(fcrCtx, {
            type: 'bar',
            data: {
                labels: <?= json_encode($fcr_flocks) ?>,
                datasets: [
                    {
                        label: 'Your Farm FCR',
                        data: <?= json_encode($fcr_values) ?>,
                        backgroundColor: '#22c55e',
                        borderColor: '#16a34a',
                        borderWidth: 1
                    },
                    {
                        label: 'Industry Benchmark (2.2)',
                        data: Array(<?= count($fcr_flocks) ?>).fill(2.2),
                        type: 'line',
                        borderColor: '#f59e0b',
                        borderWidth: 2,
                        fill: false,
                        pointRadius: 0,
                        borderDash: [5, 5]
                    }
                ]
            },
            options: { ...chartConfig }
        });
        
        // Revenue vs Expenses
        const financialCtx = document.getElementById('financialChart').getContext('2d');
        const financialChart = new Chart(financialCtx, {
            type: 'bar',
            data: {
                labels: <?= json_encode($financial_months) ?>,
                datasets: [
                    { label: 'Revenue', data: [45000, 52000, 48000, 61000, 55000, 59000], backgroundColor: '#22c55e', borderColor: '#16a34a', borderWidth: 1 },
                    { label: 'Expenses', data: [12000, 14000, 13000, 15000, 14000, 16000], backgroundColor: '#ef4444', borderColor: '#dc2626', borderWidth: 1 }
                ]
            },
            options: { ...chartConfig }
        });
        
        // Flock status donut
        const statusCtx = document.getElementById('flockStatusChart').getContext('2d');
        const statusChart = new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: <?= json_encode($flock_statuses) ?>,
                datasets: [{
                    data: <?= json_encode($flock_counts) ?>,
                    backgroundColor: <?= json_encode($flock_colors) ?>,
                    borderColor: '#080d0b',
                    borderWidth: 2
                }]
            },
            options: { ...chartConfig, plugins: { legend: { position: 'bottom' } } }
        });
        
        // Mortality trend
        const mortalityCtx = document.getElementById('mortalityChart').getContext('2d');
        const mortalityChart = new Chart(mortalityCtx, {
            type: 'line',
            data: {
                labels: <?= json_encode($mortality_dates) ?>,
                datasets: [{
                    label: 'Daily Deaths',
                    data: <?= json_encode($mortality_values) ?>,
                    borderColor: '#ef4444',
                    backgroundColor: 'rgba(239,68,68,0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 0,
                    borderWidth: 2
                }]
            },
            options: { ...chartConfig }
        });
        
        // Modal functions
        function openModal(id) {
            document.getElementById(id).style.display = 'flex';
        }
        
        function closeModal(id) {
            document.getElementById(id).style.display = 'none';
        }
        
        function openQuickRecordModal() {
            openModal('eggModal');
        }
        
        // Form submission
        function handleFormSubmit(e, formId) {
            e.preventDefault();
            const form = document.getElementById(formId);
            const formData = new FormData(form);
            
            // Map form ID to endpoint
            const endpoints = {
                'eggForm': '/poultry-farm-system/api/save_egg.php',
                'feedForm': '/poultry-farm-system/api/save_feed.php',
                'mortalityForm': '/poultry-farm-system/api/save_mortality.php',
                'vaccineForm': '/poultry-farm-system/api/save_vaccine.php'
            };
            
            fetch(endpoints[formId] || '#', {
                method: 'POST',
                body: formData
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast('✅ ' + data.message, 'success');
                    closeModal(formId.replace('Form', 'Modal'));
                    form.reset();
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showToast('❌ ' + data.error, 'error');
                }
            })
            .catch(err => showToast('❌ Network error', 'error'));
        }
        
        // Toast notifications
        function showToast(msg, type) {
            const toast = document.createElement('div');
            toast.className = 'toast toast-' + type;
            toast.textContent = msg;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
        
        // JARVIS interaction
        function askJarvis() {
            const input = document.getElementById('jarvisInput').value;
            if (!input) return;
            document.getElementById('jarvisInput').value = '';
            
            fetch('/poultry-farm-system/admin/jarvis_api.php', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ query: input })
            })
            .then(r => r.json())
            .then(data => {
                document.getElementById('jarvisInsight').innerHTML = '<p>' + (data.response || 'JARVIS thinking...') + '</p>';
            })
            .catch(() => {
                document.getElementById('jarvisInsight').innerHTML = '<p>JARVIS offline — retrying...</p>';
            });
        }
        
        function handleJarvisEnter(e) {
            if (e.key === 'Enter') askJarvis();
        }
        
        function handleJarvisChat(e) {
            if (e.key === 'Enter') {
                const input = document.getElementById('jarvisChatInput');
                const msg = input.value;
                if (!msg) return;
                input.value = '';
                
                const container = document.getElementById('jarvisChatContainer');
                container.innerHTML += '<div class="jarvis-message-user">' + htmlEscape(msg) + '</div>';
                container.innerHTML += '<div class="jarvis-message">thinking...</div>';
                container.scrollTop = container.scrollHeight;
                
                fetch('/poultry-farm-system/admin/jarvis_api.php', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ query: msg })
                })
                .then(r => r.json())
                .then(data => {
                    container.lastChild.textContent = data.response || 'No response';
                    container.scrollTop = container.scrollHeight;
                })
                .catch(() => {
                    container.lastChild.textContent = 'Connection error';
                });
            }
        }
        
        function htmlEscape(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        // Auto-refresh KPIs every 30 seconds
        setInterval(() => {
            fetch('/poultry-farm-system/api/dashboard_data.php')
            .then(r => r.json())
            .then(data => {
                document.querySelectorAll('[data-target]').forEach(el => {
                    const key = el.getAttribute('data-target');
                    // Update only if value changed
                });
            });
        }, 30000);
        
        // Live clock
        function updateClock() {
            const now = new Date();
            document.getElementById('live-clock').textContent = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit' });
        }
        updateClock();
        setInterval(updateClock, 1000);
        
        // Switch egg chart range
        function switchEggRange(range) {
            // This would fetch from API based on range parameter
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            event.target.classList.add('active');
        }
        
        // Close modal on backdrop click
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', (e) => {
                if (e.target === modal) modal.style.display = 'none';
            });
        });
    </script>
</body>
</html>
