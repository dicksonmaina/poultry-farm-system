<?php
header("Cache-Control: no-cache, no-store, must-revalidate");
session_start();

require_once __DIR__ . "/../includes/db.php";

// ═══ FETCH KPI DATA ═══
$kpi_data = [
    'total_birds' => 0,
    'eggs_today' => 0,
    'feed_today_kg' => 0,
    'active_flocks' => 0,
    'revenue_mtd' => 0,
    'mortality_rate' => 0,
];

// Total live birds
$result = $pdo->query("SELECT SUM(current_count) as total FROM flocks WHERE status='active'");
$row = $result->fetch();
$kpi_data['total_birds'] = (int)($row["total"] ?? 0);

// Eggs today
$result = $pdo->query("SELECT SUM(total_eggs) as today FROM egg_production WHERE DATE(production_date)=CURDATE()");
$row = $result->fetch();
$kpi_data['eggs_today'] = (int)($row["today"] ?? 0);

// Feed used today (kg)
$result = $pdo->query("SELECT SUM(quantity_kg) as today FROM feed_consumption WHERE DATE(consumption_date)=CURDATE()");
$row = $result->fetch();
$kpi_data['feed_today_kg'] = (float)($row["today"] ?? 0);

// Active flocks
$result = $pdo->query("SELECT COUNT(*) as count FROM flocks WHERE status='active'");
$row = $result->fetch();
$kpi_data['active_flocks'] = (int)($row["count"] ?? 0);

// Revenue MTD
$result = $pdo->query("SELECT SUM(total_price) as mtd FROM sales WHERE MONTH(sale_date)=MONTH(NOW()) AND YEAR(sale_date)=YEAR(NOW())");
$row = $result->fetch();
$kpi_data['revenue_mtd'] = (float)($row["mtd"] ?? 0);

// Mortality rate (last 7 days)
$result = $pdo->query("
  SELECT 
    ROUND((SUM(COALESCE(m.quantity,0)) / NULLIF(SUM(f.current_count),0)) * 100, 2) as rate
  FROM flocks f
  LEFT JOIN mortality m ON m.flock_id = f.id AND m.death_date >= DATE_SUB(NOW(), INTERVAL 7 DAY)
  WHERE f.status='active'
");
$row = $result->fetch();
$kpi_data['mortality_rate'] = (float)($row["rate"] ?? 0);

// ═══ FETCH CHART DATA ═══
// 30-day egg production
$egg_chart_query = "
  SELECT DATE(production_date) as d, SUM(total_eggs) as eggs 
  FROM egg_production 
  WHERE production_date >= DATE_SUB(NOW(), INTERVAL 30 DAY)
  GROUP BY DATE(production_date)
  ORDER BY d ASC
";
$egg_results = $pdo->query($egg_chart_query)->fetchAll();
$egg_dates = [];
$egg_values = [];
foreach ($egg_results as $row) {
    $egg_dates[] = date('M d', strtotime($row['d']));
    $egg_values[] = (int)$row['eggs'];
}

// FCR per flock (last 30 days)
$fcr_query = "
  SELECT 
    f.flock_name,
    ROUND(SUM(fc.quantity_kg) / NULLIF(SUM(ep.total_eggs), 0), 2) as fcr
  FROM flocks f
  LEFT JOIN feed_consumption fc ON f.id = fc.flock_id AND fc.consumption_date >= DATE_SUB(NOW(), INTERVAL 30 DAY)
  LEFT JOIN egg_production ep ON f.id = ep.flock_id AND ep.production_date >= DATE_SUB(NOW(), INTERVAL 30 DAY)
  WHERE f.status='active'
  GROUP BY f.id, f.flock_name
  ORDER BY fcr ASC
";
$fcr_results = $pdo->query($fcr_query)->fetchAll();
$fcr_flocks = [];
$fcr_values = [];
foreach ($fcr_results as $row) {
    $fcr_flocks[] = $row['flock_name'];
    $fcr_values[] = (float)($row['fcr'] ?? 0);
}

// Revenue vs Expenses (last 6 months)
$financial_query = "
  SELECT 
    DATE_FORMAT(sale_date, '%b %Y') as month,
    SUM(CASE WHEN sale_date IS NOT NULL THEN total_price ELSE 0 END) as revenue,
    SUM(CASE WHEN sale_date IS NULL THEN 0 ELSE 0 END) as expenses
  FROM sales
  WHERE sale_date >= DATE_SUB(NOW(), INTERVAL 6 MONTH)
  GROUP BY DATE_FORMAT(sale_date, '%Y-%m')
  ORDER BY sale_date ASC
";
$financial_results = $pdo->query($financial_query)->fetchAll();
$financial_months = [];
$financial_revenue = [];
for ($i = 5; $i >= 0; $i--) {
    $date = new DateTime();
    $date->modify("-$i month");
    $financial_months[] = $date->format('b Y');
}

// Flock status distribution
$flock_status_query = "SELECT COUNT(*) as count, health_status FROM flocks GROUP BY health_status";
$flock_status_results = $pdo->query($flock_status_query)->fetchAll();
$flock_statuses = [];
$flock_counts = [];
$flock_colors = [];
$color_map = ['excellent' => '#22c55e', 'good' => '#10b981', 'fair' => '#f59e0b', 'poor' => '#ef4444'];
foreach ($flock_status_results as $row) {
    $flock_statuses[] = ucfirst($row['health_status'] ?? 'unknown');
    $flock_counts[] = (int)$row['count'];
    $flock_colors[] = $color_map[$row['health_status']] ?? '#6b7280';
}

// Mortality trend (14 days)
$mortality_trend_query = "
  SELECT DATE(death_date) as d, SUM(quantity) as deaths
  FROM mortality
  WHERE death_date >= DATE_SUB(NOW(), INTERVAL 14 DAY)
  GROUP BY DATE(death_date)
  ORDER BY d ASC
";
$mortality_results = $pdo->query($mortality_trend_query)->fetchAll();
$mortality_dates = [];
$mortality_values = [];
foreach ($mortality_results as $row) {
    $mortality_dates[] = date('M d', strtotime($row['d']));
    $mortality_values[] = (int)$row['deaths'];
}

// ═══ SMART ALERTS ═══
$alerts = [];

// Low feed alert
$low_feed = $pdo->query("SELECT flock_name, current_stock FROM flocks WHERE status='active' AND current_stock < 50")->fetchAll();
foreach ($low_feed as $row) {
    $alerts[] = ['type' => 'warning', 'icon' => '⚠️', 'title' => 'Low Feed', 'message' => $row['flock_name'] . ' has < 50kg feed remaining'];
}

// High mortality alert
$high_mortality = $pdo->query("
  SELECT f.flock_name, SUM(m.quantity) as dead
  FROM mortality m
  JOIN flocks f ON m.flock_id = f.id
  WHERE m.death_date >= DATE_SUB(NOW(), INTERVAL 3 DAY)
  GROUP BY f.id, f.flock_name
  HAVING dead > 5
")->fetchAll();
foreach ($high_mortality as $row) {
    $alerts[] = ['type' => 'danger', 'icon' => '❌', 'title' => 'High Mortality', 'message' => $row['flock_name'] . ': ' . $row['dead'] . ' deaths in 3 days'];
}

// Vaccination due alert
$due_vaccines = $pdo->query("
  SELECT f.flock_name, v.vaccine_name
  FROM vaccination_schedule v
  JOIN flocks f ON v.flock_id = f.id
  WHERE v.next_due_date <= DATE_ADD(NOW(), INTERVAL 3 DAY)
  AND v.status='pending'
  LIMIT 3
")->fetchAll();
foreach ($due_vaccines as $row) {
    $alerts[] = ['type' => 'info', 'icon' => '💉', 'title' => 'Vaccination Due', 'message' => $row['vaccine_name'] . ' for ' . $row['flock_name']];
}

// No egg record today
if ($kpi_data['eggs_today'] == 0 && $kpi_data['active_flocks'] > 0) {
    $alerts[] = ['type' => 'warning', 'icon' => '🥚', 'title' => 'No Egg Record', 'message' => 'No egg collection recorded today'];
}

// ═══ ACTIVITY FEED ═══
$activity_query = "
  (SELECT 'Egg Production' as type, ep.production_date as date, CONCAT('🥚 ', f.flock_name, ' produced ', ep.total_eggs, ' eggs') as description
   FROM egg_production ep JOIN flocks f ON ep.flock_id = f.id)
  UNION
  (SELECT 'Feed', fc.consumption_date, CONCAT('🌾 ', f.flock_name, ' consumed ', fc.quantity_kg, 'kg feed') 
   FROM feed_consumption fc JOIN flocks f ON fc.flock_id = f.id)
  UNION
  (SELECT 'Sales', s.sale_date, CONCAT('💰 Sale of ', s.quantity_eggs, ' eggs for KSH ', s.total_price)
   FROM sales s)
  UNION
  (SELECT 'Mortality', m.death_date, CONCAT('📋 ', f.flock_name, ': ', m.quantity, ' deaths')
   FROM mortality m JOIN flocks f ON m.flock_id = f.id)
  ORDER BY date DESC
  LIMIT 10
";
$activity_results = $pdo->query($activity_query)->fetchAll();

$page_title = "Farm Dashboard";
?>
